PORT=3000

# Room cleanup timings, in milliseconds.
ROOM_EMPTY_TTL_MS=300000
ROOM_IDLE_TTL_MS=3600000
ROOM_SWEEP_INTERVAL_MS=30000

# Reconnect and AI takeover timings, in milliseconds.
DISCONNECT_GRACE_MS=5000
OFFLINE_TAKEOVER_MS=60000
OFFLINE_TAKEOVER_SWEEP_MS=10000

# Basic WebSocket message flood guard.
WS_MESSAGE_LIMIT=120
WS_MESSAGE_WINDOW_MS=30000
WS_MAX_PAYLOAD_BYTES=16384

# Optional comma-separated browser Origins allowed to open WebSocket connections.
# Leave empty to allow same-host Origins plus localhost/127.0.0.1 development.
WS_ALLOWED_ORIGINS=

# Set to 1 only when the app is behind a trusted reverse proxy that overwrites
# X-Forwarded-For with the real client IP.
TRUST_PROXY=0
